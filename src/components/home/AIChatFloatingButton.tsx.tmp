import { useEffect } from "react";
import styled from "styled-components";
import { motion, AnimatePresence, Variants } from "framer-motion";
import { X } from "lucide-react";
import useUserStore from "@/stores/useUserStore";
import ChatBulButtonImg from "@/assets/ai-chat/챗불이버튼.webp";
import TooltipMessage from "@/components/common/TooltipMessage";
import useAIChatStore from "@/stores/useAIChatStore";

const AIChatFloatingButton = () => {
  const { isOpen, toggleChat, closeChat } = useAIChatStore();
  const [showTooltip, setShowTooltip] = [
    useAIChatStore((state) => !state.isOpen && localStorage.getItem("showAIChatTooltip") !== "false"),
    (val: boolean) => !val && localStorage.setItem("showAIChatTooltip", "false")
  ];
  
  // 툴팁 상태를 별도로 관리 (애니메이션 및 닫기 버튼 로직을 위해)
  const [localShowTooltip, setLocalShowTooltip] = [
    useAIChatStore((state) => !state.isOpen && localStorage.getItem("showAIChatTooltip") !== "false"),
    () => localStorage.setItem("showAIChatTooltip", "false")
  ];

  // 실제 렌더링용 로컬 상태
  const [displayTooltip, setDisplayTooltip] = useEffect(() => {
    // 위 방식은 복잡하므로 단순화
  }, []);

  // 단순화된 구현
  return <AIChatFloatingButtonInner />;
};

// 내부 컴포넌트 구현
const AIChatFloatingButtonInner = () => {
  const { isOpen, toggleChat, closeChat } = useAIChatStore();
  const { tokenInfo } = useUserStore();
  const accessToken = tokenInfo.accessToken;

  const [showTooltip, setShowTooltip] = useEffect(() => {
    const stored = localStorage.getItem("showAIChatTooltip");
    return stored !== "false" && !isOpen;
  }, [isOpen]);

  // 실제 동작하는 코드로 다시 작성
  return null; 
};
